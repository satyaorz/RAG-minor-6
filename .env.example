OPENAI_API_KEY=
OPENROUTER_API_KEY=
TREEQA_LLM_PROVIDER=stub
TREEQA_LLM_MODEL=
TREEQA_LLM_BASE_URL=https://api.openai.com/v1
TREEQA_LLM_TIMEOUT_SECONDS=30
TREEQA_LLM_TEMPERATURE=0.0
TREEQA_OPENROUTER_SITE_URL=
TREEQA_OPENROUTER_APP_NAME=TreeQA
VECTOR_STORE_URL=
TREEQA_VECTOR_PROVIDER=memory
TREEQA_VECTOR_COLLECTION=
TREEQA_VECTOR_API_KEY=
GRAPH_STORE_URL=
TREEQA_GRAPH_PROVIDER=memory
TREEQA_GRAPH_DATABASE=
TREEQA_GRAPH_USERNAME=
TREEQA_GRAPH_PASSWORD=
TREEQA_GRAPH_INDEX_NAME=entity_index
TREEQA_GRAPH_QUERY=CALL db.index.fulltext.queryNodes($index_name, $question) YIELD node, score RETURN coalesce(node.id, node.name, node.title, toString(id(node))) AS source_id, coalesce(node.summary, node.description, node.value, '') AS content, score LIMIT $limit
TREEQA_DATA_DIR=data
TREEQA_MAX_RETRIES=2
TREEQA_RETRIEVAL_TOP_K=3
